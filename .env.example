# .env.example
# Copy this file to .env and fill in your values if needed

# Optional: If using a custom API endpoint
# API_ENDPOINT=https://your-custom-api.com

# Optional: API Key if using a paid service
# API_KEY=your_api_key_here

# Optional: Cloudflare account ID (for advanced features)
# CLOUDFLARE_ACCOUNT_ID=your_account_id

# Optional: Custom rate limiting
# MAX_REQUESTS_PER_MINUTE=60

# Note: For Cloudflare Pages, set environment variables in the dashboard:
# Pages → Your Project → Settings → Environment Variables
